{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1400px",
			"wideSize": "100%"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#034e9e",
					"name": "Blue"
				},
				{
					"slug": "secondary",
					"color": "#fcd026",
					"name": "Yellow"
				},
				{
					"slug": "dark-background",
					"color": "#16161A",
					"name": "Gray"
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"padding": true,
			"margin": true,
			"defaultSpacingSizes": false,
			"customSpacingSize": false,
			"spacingSizes": [
				{
					"name": "Small",
					"size": "12px",
					"slug": "eli-space-sm"
				},
				{
					"name": "Medium",
					"size": "24px",
					"slug": "eli-space-md"
				},
				{
					"name": "Large",
					"size": "50px",
					"slug": "eli-space-lg"
				},
				{
					"name": "X-Large",
					"size": "70px",
					"slug": "eli-space-xl"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem"
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Roboto, sans-serif",
					"name": "Primary Font",
					"slug": "eli-primary-font"
				}
			],
			"defaultFontSizes": false,
			"customFontSize": false,
			"letterSpacing": false,
			"lineHeight": "1.4em",
			"textColumns": false,
			"fontSizes": [
				{
					"name": "Small",
					"slug": "eli-text-1",
					"size": "16px"
				},
				{
					"name": "Medium",
					"slug": "eli-title-1",
					"size": "20px"
				},
				{
					"name": "Large",
					"slug": "eli-title-2",
					"size": "30px"
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|eli-primary-font"
		},
		"spacing": {
			"blockGap": "0px"
		},
		"blocks": {
			"core/group": {
				"spacing": {
					"padding": {
						"bottom": "0"
					}
				}
			},
			"core/columns": {
				"spacing": {
					"margin": {
						"bottom": "0"
					}
				}
			},
			"core/separator": {
				"spacing": {
					"padding": {
						"top": "20px",
						"bottom": "20px"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	],
	"version": 3
}